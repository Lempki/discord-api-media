# Required — shared secret used by Discord bots to authenticate requests
DISCORD_API_SECRET=changeme

# Optional
LOG_LEVEL=INFO
METADATA_CACHE_TTL=3600
STREAM_URL_CACHE_TTL=300
YDL_FORMAT=bestaudio/best
MAX_SEARCH_RESULTS=10

# Spotify — required for Spotify track, album, and playlist support.
# Create an app at https://developer.spotify.com/dashboard and copy the Client ID
# and Client Secret here. Without these, Spotify URLs fall back to a low-quality
# ID-based YouTube search.
# SPOTIFY_CLIENT_ID=your-client-id-here
# SPOTIFY_CLIENT_SECRET=your-client-secret-here
